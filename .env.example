# ================================
# Fleet Management System — ENV
# Copy to .env and fill in values
# ================================

# Application
NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://mongo:27017/fleet_system

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=KafxPT+s1rNYXb/Ts54XhN2US6C9zjn6oUynaOKMOFg=
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# CORS — restrict to frontend origin only
CORS_ORIGIN=http://localhost:5173

# AI / Statistical Engine (internal Docker network URL in prod)
AI_SERVICE_URL=http://ai-service:3002
AI_SERVICE_PORT=3002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend (Vite — must prefix VITE_ for client exposure)
VITE_API_BASE_URL=http://localhost:3001/api/v1
